# Copy this file to scripts/test/live.env and fill in real values.
# Then run:
#   set -a
#   source scripts/test/live.env
#   set +a
#   ./scripts/test/live_closeout.sh
#
# Optional helper (recommended) to obtain refresh token with installed-app
# PKCE + loopback flow:
#   python3 scripts/test/get_refresh_token.py --client-id "<id>" --client-secret "<secret>"

# Required for Phase 5/6 live API validation
VAS_YT_CLIENT_ID=""
VAS_YT_CLIENT_SECRET=""
VAS_YT_REFRESH_TOKEN=""

# Optional but recommended for resumable-upload interruption test (Phase 5)
VAS_YT_TEST_VIDEO_PATH=""
